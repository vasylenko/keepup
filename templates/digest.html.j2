<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>keepup — {{ week }}</title>
<style>
  :root { color-scheme: light dark; }
  body { max-width: 46rem; margin: 2rem auto; padding: 0 1rem;
         font: 16px/1.6 system-ui, sans-serif; }
  h1 { margin-bottom: 0; }
  h2 { margin-top: 2.5rem; border-bottom: 1px solid color-mix(in srgb, currentColor 25%, transparent); padding-bottom: .3rem; }
  h3 { margin-bottom: .2rem; }
  article p { margin: .2rem 0; }
  .meta, .note, .footnote { opacity: .65; font-size: .9em; }
  .links a { margin-right: .8em; }
  details { margin-top: 1.2rem; }
  summary { cursor: pointer; opacity: .8; }
  footer { margin-top: 3rem; font-size: .9em; opacity: .8; }
  footer a { margin-right: .8em; }
</style>
</head>
<body>
<header>
  <h1>keepup</h1>
  <p class="meta">Week {{ week }} · generated {{ generated.strftime('%b %d, %Y %H:%M UTC') }}</p>
</header>

{% for topic in digests %}
<section>
  <h2>{{ topic.name }}</h2>

  {% if topic.stories is none %}
    <p class="note">Synthesis unavailable this week — raw links below.</p>
  {% elif not topic.stories %}
    <p class="note">Quiet week.</p>
  {% else %}
    {% for story in topic.stories %}
    <article>
      <h3>{{ story.headline }}</h3>
      <p>{{ story.why_it_matters }}</p>
      <p class="links">
        {%- for iid in story.item_ids -%}
        {%- set item = items_by_id[topic.name][iid] -%}
        <a href="{{ item.url }}" title="{{ item.title }}">{{ item.source }}</a>
        {%- endfor -%}
      </p>
    </article>
    {% endfor %}
  {% endif %}

  {% if topic.items %}
  <details>
    <summary>All {{ topic.items | length }} items this week</summary>
    <ul>
      {% for item in topic.items %}
      <li><a href="{{ item.url }}">{{ item.title }}</a>
          <span class="meta">{{ item.source }} · {{ item.published.strftime('%b %d') }}</span></li>
      {% endfor %}
    </ul>
  </details>
  {% endif %}

  {% if topic.failed_sources %}
  <p class="footnote">Sources unavailable this week: {{ topic.failed_sources | join(', ') }}</p>
  {% endif %}
</section>
{% endfor %}

<footer>
  {% if past_weeks %}
  <p>Archive:
    {% for w in past_weeks %}<a href="{{ root }}archive/{{ w }}.html">{{ w }}</a>{% endfor %}
  </p>
  {% endif %}
  <p><a href="https://github.com/vasylenko/keepup">keepup</a> builds this page every Monday.</p>
</footer>
</body>
</html>
