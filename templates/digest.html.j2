<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>keepup — {{ week }}</title>
<style>
  /* Two-family system: serif for reading prose, sans for structure
     (headers, meta). Sizes step down h1→h3 so the source kickers never
     compete with content; body measure ≈ 70ch for comfortable scanning. */
  :root { color-scheme: light dark; }
  body { max-width: 42rem; margin: 2.5rem auto 4rem; padding: 0 1.25rem;
         font: 17px/1.65 Charter, "Bitstream Charter", "Sitka Text", Cambria, Georgia, serif; }
  h1, h2, h3, h4, .meta, .note, .footnote, .links, header p, footer {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif; }
  h1 { font-size: 1.5rem; margin-bottom: 0; }
  h2 { font-size: 1.2rem; margin: 2.8rem 0 .4rem; padding-bottom: .35rem;
       border-bottom: 1px solid color-mix(in srgb, currentColor 25%, transparent); }
  h3 { font-size: .78rem; font-weight: 600; text-transform: uppercase;
       letter-spacing: .09em; opacity: .6; margin: 1.7rem 0 .5rem; }
  h4 { font-size: 1.02rem; margin: 1.1rem 0 .15rem; }
  article p { margin: .15rem 0; }
  ul { padding-left: 1.2rem; margin: .4rem 0; }
  li { margin-bottom: .6rem; }
  a { color: inherit;
      text-decoration-color: color-mix(in srgb, currentColor 40%, transparent);
      text-underline-offset: 2px; }
  a:hover { text-decoration-color: currentColor; }
  .meta { opacity: .6; font-size: .8rem; }
  .desc { display: block; opacity: .78; font-size: .93em; }
  .note, .footnote { opacity: .65; font-size: .85rem; }
  .links { font-size: .8rem; }
  .links a { margin-right: .8em; }
  footer { margin-top: 3.5rem; font-size: .85rem; opacity: .75; }
  footer a { margin-right: .8em; }
</style>
</head>
{% macro item_list(items, show_desc=false) %}
    <ul>
      {% for item in items %}
      <li>{{ item.title }} (<a href="{{ item.url }}">link</a>)
          <span class="meta">{{ item.published.strftime('%b %d') }}</span>
          {%- if show_desc and item.excerpt %}
          <span class="desc">{{ item.excerpt | first_sentence }}</span>
          {%- endif %}</li>
      {% endfor %}
    </ul>
{% endmacro %}
<body>
<header>
  <h1>keepup</h1>
  <p class="meta">Week {{ week }} · generated {{ generated.strftime('%b %d, %Y %H:%M UTC') }}</p>
</header>

{% for topic in digests %}
<section>
  <h2>{{ topic.name }}</h2>

  {% if not topic.items %}
    <p class="note">Quiet week.</p>
  {% elif not topic.synthesize or topic.stories is none %}
    {% if topic.synthesize %}
    <p class="note">Synthesis unavailable this week — raw links instead.</p>
    {% endif %}
    {% for source, items in items_by_source[topic.name].items() %}
    <h3>{{ source }}</h3>
    {{ item_list(items, show_desc=topic.descriptions) }}
    {% endfor %}
  {% elif not topic.stories %}
    <p class="note">Quiet week.</p>
  {% else %}
    {% for vendor, stories in stories_by_vendor[topic.name].items() %}
    <h3>{{ vendor }}</h3>
    {% for story in stories %}
    <article>
      <h4>{{ story.headline }}</h4>
      <p>{{ story.why_it_matters }}</p>
      <p class="links">
        {%- for iid in story.item_ids -%}
        {%- set item = items_by_id[topic.name][iid] -%}
        <a href="{{ item.url }}" title="{{ item.title }}">{{ item.source }}</a>
        {%- endfor -%}
      </p>
    </article>
    {% endfor %}
    {% endfor %}
  {% endif %}

  {% if topic.failed_sources %}
  <p class="footnote">Sources unavailable this week: {{ topic.failed_sources | join(', ') }}</p>
  {% endif %}
</section>
{% endfor %}

<footer>
  {% if past_weeks %}
  <p>Archive:
    {% for w in past_weeks %}<a href="{{ root }}archive/{{ w }}.html">{{ w }}</a>{% endfor %}
  </p>
  {% endif %}
  <p><a href="https://github.com/vasylenko/keepup">keepup</a> builds this page every Monday.</p>
</footer>
</body>
</html>
